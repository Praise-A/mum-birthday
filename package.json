{
  "name": "mum-birthday",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n client,server -c green,blue \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "nodemon",
    "start": "tsx api/server.ts",
    "start:server": "tsx api/server.ts",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sanity/client": "^7.23.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "lucide-react": "^0.511.0",
    "multer": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "zustand": "^5.0.3",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@vitejs/plugin-react": "^4.4.1",
    "@vercel/node": "^5.3.6",
    "concurrently": "^9.2.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.1",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^2.1.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0"
  }
}
